rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────────────────
    // USER DATA: All uploads are scoped under /users/{uid}/…
    // Only the authenticated owner of a UID may read or write their files.
    // This covers receipt photos, profile images, and exported PDFs.
    // ─────────────────────────────────────────────────────────────────────
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────────────────
    // RECEIPT PHOTOS: Explicitly name the receipts sub-path for audit clarity.
    // Rule above already covers this, but naming sub-paths adds readability.
    // ─────────────────────────────────────────────────────────────────────
    match /users/{uid}/receipts/{imageId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && request.resource.size < 10 * 1024 * 1024  // Max 10 MB per image
                         && request.resource.contentType.matches('image/.*');
    }

    // ─────────────────────────────────────────────────────────────────────
    // DENY ALL: Any path not matched above is denied by default.
    // ─────────────────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
