rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────
    // ROOT: All KhataFlow user data lives under /users/{uid}/…
    // Only the authenticated owner of a UID may read or write their data.
    // Anonymous access is explicitly blocked (request.auth != null check).
    // ─────────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // User profile document (optional future use)
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;

      // ── Persons (Contacts) ───────────────────────────────────────────
      match /persons/{personId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid;
      }

      // ── Khatas (Sub-ledgers) ─────────────────────────────────────────
      match /khatas/{khataId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid;
      }

      // ── Transactions ─────────────────────────────────────────────────
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // DENY ALL: Any path not matched above is denied by default.
    // This is Firestore's default behaviour, but stated explicitly here
    // for documentation and audit clarity.
    // ─────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
